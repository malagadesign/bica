# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Usá UNA de estas dos (proyectos nuevos: publishable key):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor — Dashboard → API → Secret key (sb_secret_...) o service_role legacy
SUPABASE_SERVICE_ROLE_KEY=

# Conexión directa a Postgres (ABM local, psql, migraciones)
# Dashboard → Project Settings → Database → Connection string → "Session pooler" (IPv4)
DATABASE_URL=postgresql://postgres.<project-ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Access management
PUBLIC_REGISTRATION_ENABLED=true
